#!/usr/bin/env bash
#
# bashsupport disable=BP5007
#
# index:
#   - this::help
#   - this::init_aks
#   - this::init_custom
#   - this::init_oke
#   - this::print_empty_kubeconfig
#   - this::set_context_extension_aptakube
#   - this::set_context_namespace
#   - this::set_context_namespace_manual
#   - this::use_context
#   - this::use_context_manual
#

#######################################
# No description.
# Arguments:
#   1 - exit_code (optional, integer)
# Outputs:
#   Help message to stdout.
#######################################
this::help() {
  local exit_code
  exit_code="${1:-1}"
  cat << EOT

  Usage: ${0} [OPTION...] <ALIAS>

  Options:
    -a             Configure as (cluster) admin
    -l             List available aliases and exit
    -n <namespace> Set the specified namespace
    -r             Restore default kubeconfig files and exit
    -t <token>     Set the specified token
    -u             Unset current context and exit

  Help options:
    -H Show this help message
    -U Display brief usage
    -V Print version

  Configuration file example:
    [...]
    <alias>_aks_name=<aks1 name>
    <alias>_aks_resource_group=<aks1 resource group>
    <alias>_aks_subscription=<aks1 subscription>
    <alias>_cluster_name=<cluster name>
    <alias>_extension_aptakube_order=2
    <alias>_extension_aptakube_tags=AZ,AKS
    <alias>_kind=aks
    <alias>_kubeconfig=/Users/jobace78/.kubeconfig-aks1.yaml
    <alias>_user_name=<mail or user name>

    <alias>_cluster_name=<cluster name>
    <alias>_custom_server=https://<api address>
    <alias>_extension_aptakube_icon_url=/Users/jobace78/icon_openshift_512x512.png
    <alias>_extension_aptakube_order=1
    <alias>_extension_aptakube_tags=AWS,OCP
    <alias>_kind=custom
    <alias>_kubeconfig=/Users/jobace78/.kubeconfig-custom1.yaml
    <alias>_user_name=<mail or user name>

    <alias>_kind=manual
    <alias>_kubeconfig=/Users/jobace78/.kubeconfig-manual1.yaml
    <alias>_manual_context_name=<manual1 name>

    <alias>_cluster_name=<cluster name>
    <alias>_extension_aptakube_order=3
    <alias>_extension_aptakube_tags=OCI,OKE
    <alias>_kind=oke
    <alias>_kubeconfig=/Users/jobace78/.kubeconfig-oke1.yaml
    <alias>_oke_cluster_id=<oke1 cluster id>
    <alias>_oke_profile=<oke1 profile>
    <alias>_user_name=<mail or user name>
    [...]

  Environment variable example:
    [...]
    KUBECONFIG=":\${HOME:?}/.kube/config"
    KUBECONFIG="\${KUBECONFIG}:/Users/jobace78/.kubeconfig-aks1.yaml"
    KUBECONFIG="\${KUBECONFIG}:/Users/jobace78/.kubeconfig-custom1.yaml"
    KUBECONFIG="\${KUBECONFIG}:/Users/jobace78/.kubeconfig-manual1.yaml"
    KUBECONFIG="\${KUBECONFIG}:/Users/jobace78/.kubeconfig-oke1.yaml"
    [...]

EOT
  functions::exit "${exit_code}"
}

#######################################
# No description.
# Globals:
#   admin
# Arguments:
#   1: local_current_aks_name (required, string)
#   2: local_current_aks_resource_group (required, string)
#   3: local_current_aks_subscription (required, string)
#   4: local_current_cluster_name (required, string)
#   5: local_current_kubeconfig (required, string)
#   6: local_current_user_name (required, string)
#######################################
this::init_aks() {
  # INFO : local variables with "local" prefix to avoid "collisions"...
  local local_current_aks_name
  local local_current_aks_resource_group
  local local_current_aks_subscription
  local local_current_cluster_name
  local local_current_kubeconfig
  local local_current_user_name
  local_current_aks_name="${1:?}"
  local_current_aks_resource_group="${2:?}"
  local_current_aks_subscription="${3:?}"
  local_current_cluster_name="${4:?}"
  local_current_kubeconfig="${5:?}"
  local_current_user_name="${6:?}"
  if [ -f "${local_current_kubeconfig}" ]; then
    cat /dev/null > "${local_current_kubeconfig}"
  fi
  if [ "${admin:-}" = 'true' ]; then
    az aks get-credentials \
      --admin \
      --context "${local_current_aks_name}" \
      --file "${local_current_kubeconfig}" \
      --name "${local_current_aks_name}" \
      --resource-group "${local_current_aks_resource_group}" \
      --subscription "${local_current_aks_subscription}" 1> /dev/null
  else
    az aks get-credentials \
      --context "${local_current_aks_name}" \
      --file "${local_current_kubeconfig}" \
      --name "${local_current_aks_name}" \
      --resource-group "${local_current_aks_resource_group}" \
      --subscription "${local_current_aks_subscription}" 1> /dev/null
  fi
  yq --inplace \
    "
    .clusters[].name = \"${local_current_cluster_name}\"
    | .contexts[].context |= {\"cluster\": \"${local_current_cluster_name}\", \"namespace\": (.namespace // \"default\"), \"user\": \"${local_current_user_name}-at-${local_current_cluster_name}\"}
    | .contexts[].name = \"${local_current_cluster_name}-as-${local_current_user_name}\"
    | del(.current-context)
    | .users[].name = \"${local_current_user_name}-at-${local_current_cluster_name}\"
    " \
    "${local_current_kubeconfig}"
}

#######################################
# No description.
# Globals:
#   token
# Arguments:
#   1: local_current_cluster_name (required, string)
#   2: local_current_custom_server (required, string)
#   3: local_current_kubeconfig (required, string)
#   4: local_current_user_name (required, string)
#######################################
this::init_custom() {
  # INFO : local variables with "local" prefix to avoid "collisions"...
  local local_current_cluster_name
  local local_current_custom_server
  local local_current_kubeconfig
  local local_current_user_name
  local_current_cluster_name="${1:?}"
  local_current_custom_server="${2:?}"
  local_current_kubeconfig="${3:?}"
  local_current_user_name="${4:?}"
  oc config set-cluster \
    --kubeconfig="${local_current_kubeconfig}" \
    --server="${local_current_custom_server}" \
    "${local_current_cluster_name}" 1> /dev/null
  oc config set-context \
    --cluster="${local_current_cluster_name}" \
    --kubeconfig="${local_current_kubeconfig}" \
    --user="${local_current_user_name}-at-${local_current_cluster_name}" \
    "${local_current_cluster_name}-as-${local_current_user_name}" 1> /dev/null
  if [ -n "${token:-}" ]; then
    oc config set-credentials \
      --kubeconfig="${local_current_kubeconfig}" \
      --token="${token}" \
      "${local_current_user_name}-at-${local_current_cluster_name}" 1> /dev/null
  fi
}

#######################################
# No description.
# Arguments:
#   1: local_current_cluster_name (required, string)
#   2: local_current_kubeconfig (required, string)
#   3: local_current_oke_cluster_id (required, string)
#   4: local_current_oke_profile (required, string)
#   5: local_current_user_name (required, string)
#######################################
this::init_oke() {
  # INFO : local variables with "local" prefix to avoid "collisions"...
  local local_current_cluster_name
  local local_current_kubeconfig
  local local_current_oke_cluster_id
  local local_current_oke_profile
  local local_current_user_name
  local_current_cluster_name="${1:?}"
  local_current_kubeconfig="${2:?}"
  local_current_oke_cluster_id="${3:?}"
  local_current_oke_profile="${4:?}"
  local_current_user_name="${5:?}"
  if [ -f "${local_current_kubeconfig}" ]; then
    cat /dev/null > "${local_current_kubeconfig}"
  fi
  oci --profile "${local_current_oke_profile}" ce cluster create-kubeconfig \
    --cluster-id "${local_current_oke_cluster_id}" \
    --file "${local_current_kubeconfig}"
  yq --inplace \
    "
    .clusters[].name = \"${local_current_cluster_name}\"
    | .contexts[].context |= {\"cluster\": \"${local_current_cluster_name}\", \"namespace\": (.namespace // \"default\"), \"user\": \"${local_current_user_name}-at-${local_current_cluster_name}\"}
    | .contexts[].name = \"${local_current_cluster_name}-as-${local_current_user_name}\"
    | del(.current-context)
    | .kind = null
    | .kind = \"Config\"
    | .users[].name = \"${local_current_user_name}-at-${local_current_cluster_name}\"
    | .users[].user.exec.args = [\"--profile\", \"${local_current_oke_profile}\"] + .users[].user.exec.args
    " \
    "${local_current_kubeconfig}"
}

#######################################
# No description.
# Arguments:
#   1: path (required, string)
#######################################
this::print_empty_kubeconfig() {
  local path
  path="${1:?}"
  [ -d "$(dirname "${path}")" ] || mkdir -p "$(dirname "${path}")"
  cat << 'EOT' > "${path}"
apiVersion: v1
clusters: null
contexts: null
kind: Config
preferences: {}
users: null
EOT
}

#######################################
# No description.
# Arguments:
#   1: local_current_cluster_name (required, string)
#   2: local_current_extension_aptakube_icon_url (required, string)
#   3: local_current_extension_aptakube_order (required, string)
#   4: local_current_extension_aptakube_tags (required, string)
#   5: local_current_kubeconfig (required, string)
#######################################
this::set_context_extension_aptakube() {
  local tag_index
  tag_index=''
  # INFO : local variables with "local" prefix to avoid "collisions"...
  local local_current_cluster_name
  local local_current_extension_aptakube_icon_url
  local local_current_extension_aptakube_order
  local local_current_extension_aptakube_tags
  local local_current_extension_aptakube_tags_array
  local local_current_kubeconfig
  local_current_cluster_name="${1:?}"
  local_current_extension_aptakube_icon_url="${2:-}"
  local_current_extension_aptakube_order="${3:-}"
  local_current_extension_aptakube_tags="${4:-}"
  local_current_extension_aptakube_tags_array=()
  local_current_kubeconfig="${5:?}"
  yq --inplace \
    "(.contexts[].context | select(.cluster == \"${local_current_cluster_name}\") | .extensions[0].name) = \"aptakube\"" \
    "${local_current_kubeconfig}"
  # extension_aptakube_icon_url
  #
  yq --inplace \
    "del(.contexts[].context | select(.cluster == \"${local_current_cluster_name}\") | .extensions[0].extension.icon-url)" \
    "${local_current_kubeconfig}"
  if [ -n "${local_current_extension_aptakube_icon_url}" ]; then
    yq --inplace \
      "(.contexts[].context | select(.cluster == \"${local_current_cluster_name}\") | .extensions[0].extension.icon-url) = \"${local_current_extension_aptakube_icon_url}\"" \
      "${local_current_kubeconfig}"
  fi
  # extension_aptakube_order
  #
  yq --inplace \
    "del(.contexts[].context | select(.cluster == \"${local_current_cluster_name}\") | .extensions[0].extension.order)" \
    "${local_current_kubeconfig}"
  if [ -n "${local_current_extension_aptakube_order}" ]; then
    yq --inplace \
      "(.contexts[].context | select(.cluster == \"${local_current_cluster_name}\") | .extensions[0].extension.order) = ${local_current_extension_aptakube_order}" \
      "${local_current_kubeconfig}"
  fi
  # extension_aptakube_tags
  #
  yq --inplace \
    "del(.contexts[].context | select(.cluster == \"${local_current_cluster_name}\") | .extensions[0].extension.tags)" \
    "${local_current_kubeconfig}"
  if [ -n "${local_current_extension_aptakube_tags}" ]; then
    IFS=',' read -a local_current_extension_aptakube_tags_array -r <<< "${local_current_extension_aptakube_tags}"
    for tag_index in "${!local_current_extension_aptakube_tags_array[@]}"; do
      yq --inplace \
        "(.contexts[].context | select(.cluster == \"${local_current_cluster_name}\") | .extensions[0].extension.tags[${tag_index}]) = \"${local_current_extension_aptakube_tags_array[tag_index]}\"" \
        "${local_current_kubeconfig}"
    done
  fi
}

#######################################
# No description.
# Globals:
#   namespace
# Arguments:
#   1: local_current_cluster_name (required, string)
#   2: local_current_kubeconfig (required, string)
#   3: local_current_user_name (required, string)
#######################################
this::set_context_namespace() {
  # INFO : local variables with "local" prefix to avoid "collisions"...
  local local_current_cluster_name
  local local_current_kubeconfig
  local local_current_user_name
  local_current_cluster_name="${1:?}"
  local_current_kubeconfig="${2:?}"
  local_current_user_name="${3:?}"
  oc config set-context \
    --kubeconfig="${local_current_kubeconfig}" \
    --namespace="${namespace:?}" \
    "${local_current_cluster_name}-as-${local_current_user_name}" 1> /dev/null
}

#######################################
# No description.
# Globals:
#   namespace
# Arguments:
#   1: local_current_kubeconfig (required, string)
#   2: local_current_manual_context_name (required, string)
#######################################
this::set_context_namespace_manual() {
  # INFO : local variables with "local" prefix to avoid "collisions"...
  local local_current_kubeconfig
  local local_current_manual_context_name
  local_current_kubeconfig="${1:?}"
  local_current_manual_context_name="${2:?}"
  oc config set-context \
    --kubeconfig="${local_current_kubeconfig}" \
    --namespace="${namespace:?}" \
    "${local_current_manual_context_name}" 1> /dev/null
}

#######################################
# No description.
# Arguments:
#   1: local_current_cluster_name (required, string)
#   2: local_current_user_name (required, string)
#######################################
this::use_context() {
  # INFO : local variables with "local" prefix to avoid "collisions"...
  local local_current_cluster_name
  local local_current_user_name
  local_current_cluster_name="${1:?}"
  local_current_user_name="${2:?}"
  oc config use-context \
    "${local_current_cluster_name}-as-${local_current_user_name}"
}

#######################################
# No description.
# Arguments:
#   1: local_current_manual_context_name (required, string)
#######################################
this::use_context_manual() {
  # INFO : local variables with "local" prefix to avoid "collisions"...
  local local_current_manual_context_name
  local_current_manual_context_name="${1:?}"
  oc config use-context \
    "${local_current_manual_context_name}"
}

#######################################
# No description.
# Globals:
#   HOME
#   OCC_CONF
#   OPTARG
#   OPTIND
#   admin
#   namespace
#   token
# Arguments:
#   None
#######################################
main() {
  if [ -f "$(dirname "${0}")"/../etc/bash44.shconf ]; then
    # shellcheck source=../etc/bash44.shconf
    . "$(dirname "${0}")"/../etc/bash44.shconf || exit 1
  else
    # shellcheck source=/dev/null
    . "${HOME:?}"/.etc/bash44.shconf || exit 1
  fi

  if [ -f "$(dirname "${0}")"/../etc/constants.shconf ]; then
    # shellcheck source=../etc/constants.shconf
    . "$(dirname "${0}")"/../etc/constants.shconf
  else
    # shellcheck source=/dev/null
    . "${HOME:?}"/.etc/constants.shconf
  fi

  if [ -f "$(dirname "${0}")"/../etc/functions.shconf ]; then
    # shellcheck source=../etc/functions.shconf
    . "$(dirname "${0}")"/../etc/functions.shconf
  else
    # shellcheck source=/dev/null
    . "${HOME:?}"/.etc/functions.shconf
  fi

  admin='false'
  namespace='default'
  token=''

  local current_aks_name
  local current_aks_resource_group
  local current_aks_subscription
  local current_cluster_name
  local current_custom_server
  local current_extension_aptakube_icon_url
  local current_extension_aptakube_order
  local current_extension_aptakube_tags
  local current_kind
  local current_kubeconfig
  local current_manual_context_name
  local current_oke_cluster_id
  local current_oke_profile
  local current_user_name
  local getopts_alias
  local getopts_aliases
  local getopts_args
  local getopts_kubeconfig
  local getopts_response
  local getopts_version
  local occ_conf
  local sed
  current_aks_name=''
  current_aks_resource_group=''
  current_aks_subscription=''
  current_cluster_name=''
  current_custom_server=''
  current_extension_aptakube_icon_url=''
  current_extension_aptakube_order=''
  current_extension_aptakube_tags=''
  current_kind=''
  current_kubeconfig=''
  current_manual_context_name=''
  current_oke_cluster_id=''
  current_oke_profile=''
  current_user_name=''
  getopts_alias=''
  getopts_aliases=()
  getopts_args=''
  getopts_kubeconfig=''
  getopts_response=''
  getopts_version='v20251028'
  occ_conf="${OCC_CONF:-"${HOME:?}"/.occ.conf}"
  sed='sed'

  trap 'functions::catch_all ${?}' ERR SIGHUP SIGINT SIGQUIT SIGTERM

  case "$(uname)" in
    Darwin*)
      sed='gsed'
      ;;
  esac

  mkdir -p "${HOME:?}"/.kube

  touch "${HOME:?}"/.kube/config 1> /dev/null

  OPTIND=1
  while getopts 'aln:rt:uHUV' getopts_args; do
    case "${getopts_args}" in
      a)
        admin='true'
        ;;
      l)
        if [ -f "${occ_conf}" ]; then
          while read -r getopts_alias; do
            getopts_aliases+=("${getopts_alias/_kubeconfig/}")
          done < <(awk -F '=' '$1 ~ /_kubeconfig/ { print $1 }' "${occ_conf}" 2> /dev/null | sort -u)
          if [[ "${getopts_aliases[*]}" ]]; then
            functions::stdout "${getopts_aliases[*]}"
            functions::exit 0
          else
            functions::exit 1 "is '${occ_conf}' empty ???"
          fi
        else
          functions::exit 1 "'${occ_conf}' was NOT found, exiting."
        fi
        ;;
      n)
        namespace="${OPTARG}"
        ;;
      r)
        if [ -f "${occ_conf}" ]; then
          while read -r getopts_kubeconfig; do
            if [ -f "${getopts_kubeconfig}" ]; then
              read -p "Do you want to restore [${getopts_kubeconfig}]? (y/N) " -r getopts_response < /dev/tty
              case "${getopts_response}" in
                Y | y)
                  this::print_empty_kubeconfig "${getopts_kubeconfig}"
                  ;;
                *)
                  functions::stdout 'skipped, continuing.'
                  ;;
              esac
            fi
          done < <(awk -F '=' '$1 ~ /_kubeconfig/ { print $2 }' "${occ_conf}" 2> /dev/null | sort -u)
        fi
        read -p "Do you want to restore [${HOME:?}/.kube/config]? (Y/n) " -r getopts_response < /dev/tty
        case "${getopts_response}" in
          N | n)
            functions::stdout 'skipped, continuing.'
            ;;
          *)
            this::print_empty_kubeconfig "${HOME:?}"/.kube/config
            ;;
        esac
        functions::exit 0
        ;;
      t)
        token="${OPTARG}"
        ;;
      u)
        if [ -f "${occ_conf}" ]; then
          while read -r getopts_kubeconfig; do
            if [ -f "${getopts_kubeconfig}" ]; then
              ${sed} -i '/^current-context:/d' "${getopts_kubeconfig}"
            fi
          done < <(awk -F '=' '$1 ~ /_kubeconfig/ { print $2 }' "${occ_conf}" 2> /dev/null | sort -u)
        fi
        ${sed} -i '/^current-context:/d' "${HOME:?}"/.kube/config
        functions::exit 0
        ;;
      H | U)
        this::help 0
        ;;
      V)
        functions::exit 0 "${getopts_version}"
        ;;
      ?)
        this::help 1
        ;;
    esac
  done
  shift $((OPTIND - 1))

  [ $# -ge 1 ] || this::help 1

  getopts_alias="${1:?}"

  if [ -f "${occ_conf}" ]; then
    # common variables
    #
    current_extension_aptakube_icon_url="$(awk -F '=' -v this="^${getopts_alias}_extension_aptakube_icon_url" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
    current_extension_aptakube_order="$(awk -F '=' -v this="^${getopts_alias}_extension_aptakube_order" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
    current_extension_aptakube_tags="$(awk -F '=' -v this="^${getopts_alias}_extension_aptakube_tags" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
    current_kind="$(awk -F '=' -v this="^${getopts_alias}_kind" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
    current_kubeconfig="$(awk -F '=' -v this="^${getopts_alias}_kubeconfig" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
    case "${current_kind:?}" in
      aks)
        # aks variables
        #
        current_aks_name="$(awk -F '=' -v this="^${getopts_alias}_aks_name" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
        current_aks_resource_group="$(awk -F '=' -v this="^${getopts_alias}_aks_resource_group" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
        current_aks_subscription="$(awk -F '=' -v this="^${getopts_alias}_aks_subscription" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
        current_cluster_name="$(awk -F '=' -v this="^${getopts_alias}_cluster_name" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
        current_user_name="$(awk -F '=' -v this="^${getopts_alias}_user_name" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
        # aks
        #
        this::init_aks \
          "${current_aks_name:?}" \
          "${current_aks_resource_group:?}" \
          "${current_aks_subscription:?}" \
          "${current_cluster_name:?}" \
          "${current_kubeconfig:?}" \
          "${current_user_name:?}"
        this::set_context_namespace \
          "${current_cluster_name:?}" \
          "${current_kubeconfig:?}" \
          "${current_user_name:?}"
        this::use_context \
          "${current_cluster_name:?}" \
          "${current_user_name:?}"
        this::set_context_extension_aptakube \
          "${current_cluster_name:?}" \
          "${current_extension_aptakube_icon_url:-}" \
          "${current_extension_aptakube_order:-}" \
          "${current_extension_aptakube_tags:-}" \
          "${current_kubeconfig:?}"
        ;;
      custom)
        # custom variables
        #
        current_cluster_name="$(awk -F '=' -v this="^${getopts_alias}_cluster_name" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
        current_custom_server="$(awk -F '=' -v this="^${getopts_alias}_custom_server" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
        current_user_name="$(awk -F '=' -v this="^${getopts_alias}_user_name" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
        # custom
        #
        this::init_custom \
          "${current_cluster_name:?}" \
          "${current_custom_server:?}" \
          "${current_kubeconfig:?}" \
          "${current_user_name:?}"
        this::set_context_namespace \
          "${current_cluster_name:?}" \
          "${current_kubeconfig:?}" \
          "${current_user_name:?}"
        this::use_context \
          "${current_cluster_name:?}" \
          "${current_user_name:?}"
        this::set_context_extension_aptakube \
          "${current_cluster_name:?}" \
          "${current_extension_aptakube_icon_url:-}" \
          "${current_extension_aptakube_order:-}" \
          "${current_extension_aptakube_tags:-}" \
          "${current_kubeconfig:?}"
        ;;
      manual)
        # manual variables
        #
        current_manual_context_name="$(awk -F '=' -v this="^${getopts_alias}_manual_context_name" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
        # manual
        #
        this::set_context_namespace_manual \
          "${current_kubeconfig:?}" \
          "${current_manual_context_name:?}"
        this::use_context_manual \
          "${current_manual_context_name:?}"
        ;;
      oke)
        # oke variables
        #
        current_cluster_name="$(awk -F '=' -v this="^${getopts_alias}_cluster_name" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
        current_oke_cluster_id="$(awk -F '=' -v this="^${getopts_alias}_oke_cluster_id" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
        current_oke_profile="$(awk -F '=' -v this="^${getopts_alias}_oke_profile" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
        current_user_name="$(awk -F '=' -v this="^${getopts_alias}_user_name" '$1 ~ this { print $2 }' "${occ_conf}" 2> /dev/null)"
        # oke
        #
        this::init_oke \
          "${current_cluster_name:?}" \
          "${current_kubeconfig:?}" \
          "${current_oke_cluster_id:?}" \
          "${current_oke_profile:?}" \
          "${current_user_name:?}"
        this::set_context_namespace \
          "${current_cluster_name:?}" \
          "${current_kubeconfig:?}" \
          "${current_user_name:?}"
        this::use_context \
          "${current_cluster_name:?}" \
          "${current_user_name:?}"
        this::set_context_extension_aptakube \
          "${current_cluster_name:?}" \
          "${current_extension_aptakube_icon_url:-}" \
          "${current_extension_aptakube_order:-}" \
          "${current_extension_aptakube_tags:-}" \
          "${current_kubeconfig:?}"
        ;;
      *)
        functions::exit 1 'Unsupported kind, exiting.'
        ;;
    esac
  else
    functions::exit 1 "'${occ_conf}' was NOT found, exiting."
  fi
}

# bashsupport disable=BP5001
if [[ ${BASH_SOURCE[0]} == "${0}" ]]; then
  main "${@}"
fi
